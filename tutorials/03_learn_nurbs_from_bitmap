# Define a plotting function
def plot_surfaces(measured_surface, ideal_surface):
    fig = plt.figure(figsize=(14, 6))

    # Plot measured surface
    ax1 = fig.add_subplot(121, projection='3d')
    for facet in measured_surface.facets:
        nurbs_surface = facet.create_nurbs_surface()
        points, _ = nurbs_surface.calculate_surface_points_and_normals()
        points_3d = points[:, :3].detach().cpu().numpy()
        ax1.scatter(points_3d[:, 0], points_3d[:, 1], points_3d[:, 2], s=1)
    ax1.set_title("Measured Surface")
    ax1.set_xlabel("X")
    ax1.set_ylabel("Y")
    ax1.set_zlabel("Z")

    # Plot ideal surface
    ax2 = fig.add_subplot(122, projection='3d')
    for facet in ideal_surface.facets:
        nurbs_surface = facet.create_nurbs_surface()
        points, _ = nurbs_surface.calculate_surface_points_and_normals()
        points_3d = points[:, :3].detach().cpu().numpy()
        ax2.scatter(points_3d[:, 0], points_3d[:, 1], points_3d[:, 2], s=1)
    ax2.set_title("Ideal Surface")
    ax2.set_xlabel("X")
    ax2.set_ylabel("Y")
    ax2.set_zlabel("Z")

    plt.tight_layout()
    plt.show()

# Call the plotting function
plot_surfaces(nurbs_surface_measured, nurbs_surface_ideal)


